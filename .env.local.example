# Anthropic API key -- from console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Klaviyo private API key -- from Klaviyo (MCF account) > Settings > API Keys
# Must be a Private Key (not the public/site ID)
KLAVIYO_PRIVATE_KEY=your_klaviyo_private_key_here

# Strapi backend URL -- your Railway deployment URL (not currently in use)
STRAPI_URL=https://your-strapi-url.up.railway.app

# Strapi API token -- create in Strapi admin under Settings > API Tokens
STRAPI_API_TOKEN=your_token_here

# Google Analytics 4 Measurement ID -- from GA4 > Admin > Data Streams > Web Stream
# Format: G-XXXXXXXXXX
# This is a public-facing key (NEXT_PUBLIC_ prefix) -- safe to expose in browser
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
